externalal printf(f, args): io:format
functionction printfln(f, args): printf(f ++ "\n", args)
functionction println(s): printfln(s, [])


functionction echo(sender):
  receive:
  | Message -> 
    println("echo Received message");
    send(sender, Done)


publiclic functionction main():
  let main_pid = self() in
  let echo_pid = spawn(fun(): echo(main_pid)) in
  send(echo_pid, Message);
  receive:
  | Done ->
    println("main Received response");
    Ok