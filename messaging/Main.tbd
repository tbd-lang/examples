external printf(f, args): io:format
function printfln(f, args): printf(f ++ "\n", args)
function println(s): printfln(s, [])


function echo(sender):
  receive:
  | Message -> 
    println("echo Received message");
    send(sender, Done)


public function main():
  let main_pid = self() in
  let echo_pid = spawn(fun(): echo(main_pid)) in
  send(echo_pid, Message);
  receive:
  | Done ->
    println("main Received response");
    Ok