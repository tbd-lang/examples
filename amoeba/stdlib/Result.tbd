import stdlib.Logging


pub fun map_error(f, result) =
  match result with
  | Error(error) -> Error(f(error))
  | Ok(value) -> Ok(value)


pub fun map(f, result) =
  match result with
  | Error(error) -> Error(error)
  | Ok(value) -> Ok(f(value))


pub fun log_error(result) =
  map_error(fun(e) -> Logging.error("~s", [e]), result)
