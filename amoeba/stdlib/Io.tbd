pub extern printf(f, args) = "io:format"
pub fun print(s) = printf(String.to_bytes(s), [])
pub fun printfln(f, args) = printf(String.to_bytes(f ++ "\n"), args)
pub fun println(s) = printfln(s, [])

extern erlang_input(prompt) = "io:get_line"
pub fun input(prompt) = erlang_input(prompt) |> String.trim()
