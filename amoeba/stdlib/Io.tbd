public external printf(f, args) = "io:format"
public function print(s) = printf(stdlib.String.to_bytes(s), [])
public function printfln(f, args) = printf(stdlib.String.to_bytes(f ++ "\n"), args)
public function println(s) = printfln(s, [])

external erlang_input(prompt) = "io:get_line"
public function input(prompt) = erlang_input(prompt) |> stdlib.String.trim()
