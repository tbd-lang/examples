pub fun info(message, args) =
  Io.printfln("[Inf] " ++ message, args)

pub fun info(message) =
  Io.printfln("[Inf] " ++ message, [])


pub fun error(message, args) =
  Io.printfln("[Err] " ++ message, args)

pub fun error(message) =
  Io.printfln("[Err] " ++ message, [])


pub fun debug(message, args) =
  Io.printfln("[Dbg] " ++ message, args)

pub fun debug(message) =
  Io.printfln("[Dbg] " ++ message, [])
