import stdlib.List
import stdlib.String
import stdlib.Process
import stdlib.Io


function convert_number_chars(negative, f, number_chars) =
  let number_chars =
    match negative with
    | true -> '-' :: number_chars
    | false -> number_chars
  in
  match
    number_chars 
    |> List.rev() 
    |> String.from_bytes() 
    |> f()
  with
  | Some(number) -> number
  | None -> Process.exit(Parse_number_error)


function parse_float(negative, chars) =
  function aux(chars, number_chars) =
    match chars with
    | [] -> {[], number_chars}
    | '.' :: chars -> aux(chars, '.' :: number_chars)
    | c :: chars when c >= '0' && c <= '9' -> aux(chars, c :: number_chars)
    | _ -> Process.exit(Parse_number_error)
  in
  let {chars, number_chars} = aux(chars, []) in
  let number =
    convert_number_chars(
      negative,
      fun(v) -> String.to_float(v),
      number_chars) 
  in
  {chars, Json_float(number)}


function parse_int(negative, chars) =
  function aux(chars, number_chars) =
    match chars with
    | [] -> {[], number_chars}
    | '.' :: _ ->
      let chars = List.append(number_chars, chars) in
      parse_float(negative, chars)
    | c :: chars when c >= '0' && c <= '9' -> aux(chars, c :: number_chars)
    | _ -> Process.exit(Parse_number_error)
  in
  let {chars, number_chars} = aux(chars, []) in
  let number =
    convert_number_chars(
      negative,
      fun(v) -> String.to_int(v),
      number_chars) 
  in
  {chars, Json_int(number)}


public function parse(chars) =
  let {negative, chars} =
    match chars with
    | '-' :: chars -> {true, chars}
    | _ -> {false, chars}
  in
  match chars with
  | '0' :: _ -> parse_float(negative, chars)
  | c :: _ when c >= '1' && c <= '9' -> parse_int(negative, chars)
  | _ -> Process.exit(Parse_number_error)
