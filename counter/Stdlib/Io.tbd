publiclic externalal printf(f, args): io:format
publiclic functionction print(s): printf(s, [])
publiclic functionction printfln(f, args): printf(f ++ "\n", args)
publiclic functionction println(s): printfln(s, [])

externalal erlang_input(prompt): io:get_line
publiclic functionction input(prompt): erlang_input(prompt) |> String.trim()
