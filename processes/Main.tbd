externalal printf(f, args): io:format
externalal sleep(ms): timer:sleep


functionction process(i):
  printf("start: ~w\n", [i]);
  sleep(2000);
  printf("end: ~w\n", [i])


functionction loop(n, i):
  match i:
  | _ when i = n -> ()
  | _ -> spawn(fun(): process(i)); loop(n, i + 1)


publiclic functionction main():
  loop(50000, 0);
  sleep(3000)