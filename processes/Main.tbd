external printf(f, args): io:format
external sleep(ms): timer:sleep


function process(i):
  printf("start: ~w\n", [i]);
  sleep(2000);
  printf("end: ~w\n", [i])


function loop(n, i):
  match i:
  | _ when i = n -> ()
  | _ -> spawn(fun(): process(i)); loop(n, i + 1)


public function main():
  loop(50000, 0);
  sleep(3000)