functionction print_item({index, state, name}):
  match state:
  | Not_done -> Io.printfln("~w. [ ] ~s", [index, name])
  | Done -> Io.printfln("~w. [x] ~s", [index, name])


functionction list_items(items):
  List.iter(print_item, items)


functionction mark_item(index, items):
  functionction aux(items', out):
    match items':
    | [] -> List.rev(out)
    | {index', state, name} :: tl ->
      match index = index':
      | True -> aux(tl, {index', Done, name} :: out)
      | False -> aux(tl, {index', state, name} :: out)
  in
  aux(items, [])


functionction reset(): Io.println("\ec")


functionction loop(index, items):
  reset();
  Io.println("Todo List");
  list_items(List.rev(items));

  match Io.input("add/mark/exit: "):
  | "add" ->
    let name = Io.input("name: ") in
    let items' = {index, Not_done, name} :: items in
    loop(index + 1, items')

  | "mark" ->
    let item = Io.input("index: ") |> String.to_integer() in
    let items' = mark_item(item, items) in
    loop(index, items')

  | "exit" -> ()

  | _ -> Io.println("not an action"); loop(index, items)


publiclic functionction main():
  loop(1, [])